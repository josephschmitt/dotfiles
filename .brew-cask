# Install native apps
brew tap phinze/homebrew-cask
brew install brew-cask

function installcask() {
	brew cask install "${@}" 2> /dev/null
}

installcask alfred
installcask airfoil
installcask cloudapp
installcask dropbox
installcask evernote
# installcask fantastical
installcask github
installcask google-chrome
