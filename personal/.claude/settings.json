{
  "permissions": {
    "allow": [
      "Bash(gh pr *)"
    ],
    "defaultMode": "plan"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/tmux-notify.sh"
          }
        ]
      },
      {
        "matcher": "permission_prompt|elicitation_dialog",
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status waiting"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status done"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "workmux set-window-status working"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-code-plugins": false,
    "commit-commands@claude-code-plugins": true,
    "feature-dev@claude-code-plugins": true,
    "frontend-design@claude-code-plugins": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "pr-review-toolkit@claude-code-plugins": false,
    "security-guidance@claude-code-plugins": false,
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "vault@knowledge-tools": true
  },
  "extraKnownMarketplaces": {
    "monocle": {
      "source": {
        "source": "github",
        "repo": "josephschmitt/monocle"
      },
      "autoUpdate": true
    },
    "knowledge-tools": {
      "source": {
        "source": "github",
        "repo": "josephschmitt/knowledge-tools"
      }
    }
  },
  "pluginConfigs": {
    "vault@knowledge-tools": {
      "options": {
        "mcp_url": "https://knowledge.schmitt.town/mcp"
      }
    }
  },
  "sandbox": {
    "network": {},
    "excludedCommands": [
      "gh"
    ]
  },
  "tui": "fullscreen",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
