#!/usr/bin/env bash
#
# nix_bump — bump the custom nix derivation pins for THIS machine.
#
# Sister to the `nix_update` / `nix_rebuild` aliases:
#   • nix_update   → bump nixpkgs (flake update) + rebuild the profile
#   • nix_rebuild  → rebuild the profile from the current config
#   • nix_bump     → THIS: bump the pinned custom derivations
#                    (buildGoModule + fetchFromGitHub: tsshd, monocle,
#                    knowledge-tools) — version + src hash + vendorHash.
#
# The same pins are copy-pasted across configs (the ubuntu-server flake and
# each nix-darwin machine file). This script edits ONLY the config that
# applies to the machine it runs on — resolved the same way `nix_rebuild`
# picks its target:
#   • Linux  → ubuntu-server/.config/nix/flake.nix
#   • macOS  → the nix-darwin machine file matching `hostname -s`
# The other machines' copies are intentionally left alone; bump them there.
#
# When it's done, apply the change with `nix_rebuild`.
#
# Usage:
#   nix_bump                          Bump every pin to its latest tag
#   nix_bump DEP [DEP...]             Bump the named pins. Each DEP is one of:
#                                       NAME            → bump to latest tag
#                                       NAME@VERSION    → pin to an explicit version
#   nix_bump --list                   List this machine's pins and versions
#
# Examples:
#   nix_bump knowledge-tools@0.6.0 monocle@0.48.1
#   nix_bump tsshd knowledge-tools           # both to latest
#
# Flags:
#   --no-build      Patch hashes but skip the per-pin verify build
#   -n, --dry-run   Show what would change without writing
#   -h, --help      This help
#
set -euo pipefail

DOTFILES="${DOTFILES_DIR:-$HOME/dotfiles}"
FAKE_HASH="sha256-AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="

die()  { printf 'nix_bump: %s\n' "$*" >&2; exit 1; }
info() { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33mwarn:\033[0m %s\n' "$*" >&2; }

command -v nix >/dev/null || die "nix not found on PATH"

# ---- resolve this machine's pin file ---------------------------------------
#
# Sets:
#   TARGET      absolute path to the nix file holding this machine's pins
#   KIND        "flake" (ubuntu-server) or "darwin" (nix-darwin machine)
#   BUILD_REF   nix installable that evaluates the pins (for vendorHash)
#   BUILD_ARGS  extra `nix build` args (e.g. --impure for private profiles)
detect_target() {
  if [[ "$(uname -s)" == "Darwin" ]]; then
    local host; host="$(hostname -s)"
    local found=""
    local profile
    for profile in shared work rca; do
      local f="$DOTFILES/$profile/.config/nix-darwin/machines/$host.nix"
      [[ -f "$f" ]] && { found="$f"; [[ "$profile" != "shared" ]] && PRIVATE=true; break; }
    done
    [[ -n "$found" ]] || die "no nix-darwin machine file for host '$host'"
    KIND="darwin"
    TARGET="$found"
    if [[ "${PRIVATE:-false}" == "true" ]]; then
      BUILD_REF="git+file://$DOTFILES?dir=shared/.config/nix-darwin&submodules=1#darwinConfigurations.$host.system"
      BUILD_ARGS="--impure"
    else
      BUILD_REF="git+file://$DOTFILES?dir=shared/.config/nix-darwin#darwinConfigurations.$host.system"
      BUILD_ARGS=""
    fi
  else
    KIND="flake"
    FLAKE_DIR="$DOTFILES/ubuntu-server/.config/nix"
    TARGET="$FLAKE_DIR/flake.nix"
    BUILD_ARGS=""
  fi
  [[ -f "$TARGET" ]] || die "pin file not found: $TARGET"
}

# ---- nix file parsing helpers (indentation-agnostic) -----------------------

# Line range "start,end" of a `<pkg> = pkgs.buildGoModule` let-binding. The
# block closes at a `};` line indented exactly like its opening line — works
# for the flake (6-space) and nix-darwin machine files (2-space) alike.
block_range() {
  local pkg="$1"
  awk -v pkg="$pkg" '
    !start && $0 ~ ("^[[:space:]]*" pkg " = pkgs.buildGoModule") {
      start = NR
      match($0, /^[[:space:]]*/)
      ind = substr($0, 1, RLENGTH)
      next
    }
    start && $0 ~ ("^" ind "};[[:space:]]*$") { print start "," NR; exit }
  ' "$TARGET"
}

# Extract a `field = "value";` from within a block range.
block_field() {
  local range="$1" field="$2"
  sed -n "${range}p" "$TARGET" \
    | grep -oE "^[[:space:]]*${field} = \"[^\"]*\"" \
    | head -n1 | sed -E "s/.*\"([^\"]*)\"/\1/"
}

# Every custom pin (pname) in this machine's file.
list_pins() {
  grep -oE '^[[:space:]]*[a-z0-9-]+ = pkgs.buildGoModule' "$TARGET" \
    | sed -E 's/^[[:space:]]*([a-z0-9-]+) .*/\1/'
}

# Latest semver tag for a pin, honoring its rev prefix ("v" or "cli/v").
latest_version() {
  local owner="$1" repo="$2" prefix="$3"
  git ls-remote --tags "https://github.com/${owner}/${repo}.git" "refs/tags/${prefix}*" 2>/dev/null \
    | sed "s#.*refs/tags/${prefix}##" \
    | grep -E '^[0-9]+\.[0-9]+\.[0-9]+$' \
    | sort -V | tail -n1
}

# SRI hash of a tag's source tree (matches fetchFromGitHub).
prefetch_src() {
  local owner="$1" repo="$2" tag="$3"
  nix store prefetch-file --json --unpack \
    "https://github.com/${owner}/${repo}/archive/refs/tags/${tag}.tar.gz" 2>/dev/null \
    | sed -En 's/.*"hash"[[:space:]]*:[[:space:]]*"([^"]*)".*/\1/p'
}

# Patch a field within a block range (scoped so we never touch other pins).
# Avoids `sed -i` — GNU takes no suffix, BSD/macOS requires one; a temp file
# rewritten in place is portable and preserves the target's perms/inode.
patch_field() {
  local range="$1" field="$2" value="$3"
  local esc; esc=$(printf '%s' "$value" | sed -e 's/[\/&]/\\&/g')
  local tmp; tmp=$(mktemp)
  sed "${range} s/\(${field} = \"\)[^\"]*\(\"\)/\1${esc}\2/" "$TARGET" >"$tmp"
  cat "$tmp" >"$TARGET"
  rm -f "$tmp"
}

# ---- build helpers ---------------------------------------------------------

# `nix build` invocation that evaluates this machine's pins. For the flake we
# build the individual package attr; for a darwin machine, the whole system
# (which references the pin) — either way a fake vendorHash surfaces the
# real one in a "hash mismatch … got:" line.
run_build() {
  local pkg="$1"
  if [[ "$KIND" == "flake" ]]; then
    (cd "$FLAKE_DIR" && nix build ".#${pkg}" ${BUILD_ARGS} 2>&1)
  else
    nix build "$BUILD_REF" ${BUILD_ARGS} 2>&1
  fi
}

# Set a fake vendorHash, build, and read the real one from the mismatch.
# The build is *expected* to fail (fake hash), and a missing match is handled
# by the caller — so capture output first and never let this abort `set -e`.
derive_vendor_hash() {
  local pkg="$1" range="$2" out
  patch_field "$range" "vendorHash" "$FAKE_HASH"
  out=$(run_build "$pkg" || true)
  printf '%s\n' "$out" \
    | grep -oE 'got:[[:space:]]+sha256-[A-Za-z0-9+/=]+' \
    | sed -E 's/.*(sha256-[A-Za-z0-9+/=]+).*/\1/;q' || true
}

# ---- per-pin bump ----------------------------------------------------------

bump_pin() {
  local pkg="$1" want_version="$2" range owner repo rev_tmpl prefix
  local cur_version cur_vendor new_version new_tag new_src_hash new_vendor_hash

  range=$(block_range "$pkg")
  [[ -n "$range" ]] || die "no buildGoModule pin named '$pkg' in $(basename "$TARGET")"

  owner=$(block_field "$range" "owner")
  repo=$(block_field "$range" "repo")
  rev_tmpl=$(block_field "$range" "rev")           # e.g. v${version} or cli/v${version}
  cur_version=$(block_field "$range" "version")
  cur_vendor=$(block_field "$range" "vendorHash")
  prefix="${rev_tmpl%%\$\{version\}*}"             # strip ${version} → tag prefix

  if [[ -n "$want_version" ]]; then
    new_version="$want_version"
  else
    info "$pkg: resolving latest tag (${owner}/${repo}, prefix '${prefix}')"
    new_version=$(latest_version "$owner" "$repo" "$prefix")
    [[ -n "$new_version" ]] || die "$pkg: could not resolve a latest version"
  fi

  if [[ "$new_version" == "$cur_version" ]]; then
    info "$pkg: already at $cur_version — skipping"
    return 0
  fi

  new_tag="${prefix}${new_version}"
  info "$pkg: $cur_version → $new_version (tag $new_tag)"
  CHANGED=true

  if $DRY_RUN; then
    info "$pkg: [dry-run] would prefetch $new_tag and rebuild"
    return 0
  fi

  info "$pkg: prefetching source hash"
  new_src_hash=$(prefetch_src "$owner" "$repo" "$new_tag")
  [[ -n "$new_src_hash" ]] || die "$pkg: prefetch failed for $new_tag"

  patch_field "$range" "version" "$new_version"
  patch_field "$range" "hash" "$new_src_hash"

  info "$pkg: deriving vendorHash"
  new_vendor_hash=$(derive_vendor_hash "$pkg" "$range")
  if [[ -z "$new_vendor_hash" ]]; then
    # No mismatch surfaced (build broke for another reason, or parsing failed).
    # Restore the original vendorHash and flag it for a human.
    patch_field "$range" "vendorHash" "$cur_vendor"
    warn "$pkg: could not derive vendorHash; restored original — verify by hand"
  else
    patch_field "$range" "vendorHash" "$new_vendor_hash"
    info "$pkg: vendorHash → $new_vendor_hash"
  fi

  if $DO_BUILD; then
    info "$pkg: verifying build"
    if run_build "$pkg" >/dev/null 2>&1; then
      [[ "$KIND" == "flake" ]] && rm -f "$FLAKE_DIR/result"
    else
      warn "$pkg: verify build failed — check $(basename "$TARGET") before rebuilding"
    fi
  fi
}

# ---- arg parsing -----------------------------------------------------------

DRY_RUN=false
DO_BUILD=true
declare -a PKGS=()     # pin names, in order
declare -A WANT=()     # pin name → requested version ("" = latest)
LIST=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-build)    DO_BUILD=false; shift ;;
    -n|--dry-run)  DRY_RUN=true; shift ;;
    --list)        LIST=true; shift ;;
    -h|--help)     awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "$0"; exit 0 ;;
    -*)            die "unknown flag: $1" ;;
    *)             # DEP or DEP@VERSION
      name="${1%%@*}"
      ver=""
      [[ "$1" == *@* ]] && ver="${1#*@}"
      [[ -n "$name" ]] || die "invalid argument: '$1'"
      PKGS+=("$name")
      WANT["$name"]="$ver"
      shift ;;
  esac
done

detect_target
info "target: ${TARGET#$DOTFILES/} ($KIND)"

if $LIST; then
  printf '%-18s %s\n' "PIN" "VERSION"
  for p in $(list_pins); do
    printf '%-18s %s\n' "$p" "$(block_field "$(block_range "$p")" version)"
  done
  exit 0
fi

# No pins named → bump every pin in this machine's file to latest.
if [[ ${#PKGS[@]} -eq 0 ]]; then
  mapfile -t PKGS < <(list_pins)
fi

CHANGED=false
for pkg in "${PKGS[@]}"; do
  bump_pin "$pkg" "${WANT[$pkg]:-}"
done

if ! $CHANGED; then
  info "nothing to do — pins already up to date"
  exit 0
fi

if $DRY_RUN; then
  info "[dry-run] no files changed"
else
  info "${TARGET##*/} updated — apply it with: nix_rebuild"
fi
