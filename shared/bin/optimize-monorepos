#!/bin/sh
# One-time fixup for repos pre-cloned by the sandbox image before dotfiles
# were stowed.
#
# The sandbox image clones repos with git's default wide refspec
# (+refs/heads/*:refs/remotes/origin/*) and full tag fetching. Once dotfiles
# land, .gitconfig-monorepo's `tagOpt = --no-tags` (activated per-repo via
# [includeIf] in each profile's .gitconfig) stops *future* tag fetches, but it
# can't narrow a fetch refspec that's already baked into an existing clone,
# and it can't remove refs/tags or remote-tracking branches that already
# exist locally. This script does that narrowing/pruning once.
#
# Repo list is intentionally NOT hardcoded here: any directory directly under
# the development dir that is a git repo AND already has .gitconfig-monorepo
# active (sentinel: remote.origin.tagOpt == --no-tags) gets optimized.
# Whether a repo is a "monorepo" is controlled entirely by the [includeIf]
# entries in the active profile's .gitconfig -- no duplication here.
#
# Usage: optimize-monorepos [--gc] [--branch-prefix PREFIX] [--dir DIR]
#   --gc                 also run `git gc --aggressive --prune=now` per repo (slow)
#   --branch-prefix STR  branch namespace to keep, besides master (default: jjs)
#   --dir DIR            where repos live (default: ~/development)
#
# Env vars (used when the equivalent flag isn't passed):
#   MONOREPO_BRANCH_PREFIX  same as --branch-prefix
#   DEVELOPMENT_DIR         same as --dir

set -eu

info() { printf '\n\033[1;34m==>\033[0m %s\n' "$*"; }
ok()   { printf '\033[0;32m✓\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!\033[0m %s\n' "$*" >&2; }
err()  { printf '\033[0;31m✗\033[0m %s\n' "$*" >&2; }

RUN_GC=0
BRANCH_PREFIX="${MONOREPO_BRANCH_PREFIX:-jjs}"
DEV_DIR="${DEVELOPMENT_DIR:-$HOME/development}"

while [ $# -gt 0 ]; do
  case "$1" in
    --gc) RUN_GC=1; shift ;;
    --branch-prefix) BRANCH_PREFIX="$2"; shift 2 ;;
    --dir) DEV_DIR="$2"; shift 2 ;;
    *)
      err "unknown argument: $1"
      exit 1
      ;;
  esac
done

[ -d "$DEV_DIR" ] || exit 0

for repo in "$DEV_DIR"/*/; do
  repo="${repo%/}"
  [ -d "$repo/.git" ] || continue
  name=$(basename "$repo")

  tag_opt=$(git -C "$repo" config remote.origin.tagOpt 2>/dev/null || true)
  if [ "$tag_opt" != "--no-tags" ]; then
    warn "$name: skipping (monorepo config not active)"
    continue
  fi

  info "$name"

  # Narrow fetch refspec to master + ${BRANCH_PREFIX}/*. `set-branches` is
  # idempotent, so it's safe to run unconditionally even if already narrowed.
  git -C "$repo" remote set-branches origin master "${BRANCH_PREFIX}/*"

  # Delete all local tags (tagOpt only prevents future fetches) and any
  # remote-tracking branch outside master/${BRANCH_PREFIX}/* in one pass.
  git -C "$repo" for-each-ref --format='delete %(refname)' refs/tags refs/remotes/origin \
    | grep -vE "^delete refs/remotes/origin/(HEAD|master|${BRANCH_PREFIX}/)" \
    | git -C "$repo" update-ref --stdin

  if [ "$RUN_GC" -eq 1 ]; then
    git -C "$repo" gc --aggressive --prune=now
  fi

  ok "$name optimized"
done
