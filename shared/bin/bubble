#!/bin/sh
# bubble - Interactive dialog wrapper around gum
# Prompts for user input and runs a command with the result.
# Works standalone or inside tmux popups.
#
# Usage: bubble <mode> [options] [choices...] [-- command [args...]]

set -e

show_help() {
  cat <<EOF
bubble - Interactive gum dialog wrapper

USAGE:
  bubble <mode> [options] [choices...] [-- command [args...]]

MODES:
  input    Single-line text input
  choose   Pick from a list of choices
  confirm  Yes/no confirmation
  write    Multi-line text input
  filter   Fuzzy filter a list

OPTIONS:
  -H, --header TEXT        Header text shown above the prompt
  -p, --prompt TEXT        Inline prompt prefix (input, filter)
      --placeholder TEXT   Ghost text hint (input, write, filter)
  -V, --value TEXT         Pre-filled default value (input, write, filter)
      --char-limit N       Max characters (input)
      --password           Mask input (input)
      --height N           Component height (write, choose, filter)
      --affirmative TEXT   Yes button label (confirm)
      --negative TEXT      No button label (confirm)
      --default            Default to yes (confirm)
      --allow-empty        Allow empty input (run command with no argument)
  -h, --help               Show this help

COMMAND TEMPLATE:
  Everything after -- is the command to run with the result.
  If {} appears as an argument, it is replaced with the user's input.
  If no {}, the input is appended as the last argument.
  For confirm mode, the command runs on "yes" (no substitution).
  If no command is given, the result is printed to stdout.

EXAMPLES:
  bubble input -H "Branch name" -- workmux add
  bubble choose dev staging prod -H "Deploy to" -- deploy-to {}
  bubble confirm -H "Force push?" -- git push --force origin main
  git branch --format='%(refname:short)' | bubble filter -H "Checkout" -- git checkout {}
  NAME=\$(bubble input -H "Session name")

EOF
}

# Check for gum
if ! command -v gum >/dev/null 2>&1; then
  echo "Error: gum is not installed" >&2
  echo "Install with: brew install gum" >&2
  exit 1
fi

# Need at least a mode argument
if [ $# -eq 0 ]; then
  show_help
  exit 1
fi

# Parse mode
MODE="$1"
shift

case "$MODE" in
  input|choose|confirm|write|filter) ;;
  -h|--help)
    show_help
    exit 0
    ;;
  *)
    echo "Error: Unknown mode: $MODE" >&2
    echo "Valid modes: input, choose, confirm, write, filter" >&2
    echo "Use --help for usage information" >&2
    exit 1
    ;;
esac

# Parse options
HEADER=""
PROMPT=""
PLACEHOLDER=""
VALUE=""
CHAR_LIMIT=""
PASSWORD=""
HEIGHT=""
AFFIRMATIVE=""
NEGATIVE=""
DEFAULT=""
ALLOW_EMPTY=""
CHOICES=""
CMD_ARGS=""
HAS_CMD=false

while [ $# -gt 0 ]; do
  case "$1" in
    --)
      shift
      HAS_CMD=true
      # Remaining args are the command
      CMD_ARGS="$*"
      break
      ;;
    -H|--header)
      HEADER="$2"
      shift 2
      ;;
    -p|--prompt)
      PROMPT="$2"
      shift 2
      ;;
    --placeholder)
      PLACEHOLDER="$2"
      shift 2
      ;;
    -V|--value)
      VALUE="$2"
      shift 2
      ;;
    --char-limit)
      CHAR_LIMIT="$2"
      shift 2
      ;;
    --password)
      PASSWORD=true
      shift
      ;;
    --height)
      HEIGHT="$2"
      shift 2
      ;;
    --affirmative)
      AFFIRMATIVE="$2"
      shift 2
      ;;
    --negative)
      NEGATIVE="$2"
      shift 2
      ;;
    --default)
      DEFAULT=true
      shift
      ;;
    --allow-empty)
      ALLOW_EMPTY=true
      shift
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    -*)
      echo "Error: Unknown option: $1" >&2
      echo "Use --help for usage information" >&2
      exit 1
      ;;
    *)
      # Positional args are choices (for choose/filter)
      CHOICES="${CHOICES:+$CHOICES
}$1"
      shift
      ;;
  esac
done

# Store command args in a way we can reconstruct them
# We need to save them before we overwrite positional params
SAVED_CMD="$CMD_ARGS"

# Build gum command arguments
set --

case "$MODE" in
  input)
    set -- "input"
    [ -n "$HEADER" ] && set -- "$@" --header "$HEADER"
    [ -n "$PROMPT" ] && set -- "$@" --prompt "$PROMPT"
    [ -n "$PLACEHOLDER" ] && set -- "$@" --placeholder "$PLACEHOLDER"
    [ -n "$VALUE" ] && set -- "$@" --value "$VALUE"
    [ -n "$CHAR_LIMIT" ] && set -- "$@" --char-limit "$CHAR_LIMIT"
    [ -n "$PASSWORD" ] && set -- "$@" --password
    ;;
  choose)
    set -- "choose"
    [ -n "$HEADER" ] && set -- "$@" --header "$HEADER"
    [ -n "$HEIGHT" ] && set -- "$@" --height "$HEIGHT"
    ;;
  confirm)
    set -- "confirm"
    [ -n "$HEADER" ] && set -- "$@" "$HEADER"
    [ -n "$AFFIRMATIVE" ] && set -- "$@" --affirmative "$AFFIRMATIVE"
    [ -n "$NEGATIVE" ] && set -- "$@" --negative "$NEGATIVE"
    [ -n "$DEFAULT" ] && set -- "$@" --default
    ;;
  write)
    set -- "write"
    [ -n "$HEADER" ] && set -- "$@" --header "$HEADER"
    [ -n "$PLACEHOLDER" ] && set -- "$@" --placeholder "$PLACEHOLDER"
    [ -n "$VALUE" ] && set -- "$@" --value "$VALUE"
    [ -n "$HEIGHT" ] && set -- "$@" --height "$HEIGHT"
    ;;
  filter)
    set -- "filter"
    [ -n "$HEADER" ] && set -- "$@" --header "$HEADER"
    [ -n "$PROMPT" ] && set -- "$@" --prompt "$PROMPT"
    [ -n "$PLACEHOLDER" ] && set -- "$@" --placeholder "$PLACEHOLDER"
    [ -n "$VALUE" ] && set -- "$@" --value "$VALUE"
    [ -n "$HEIGHT" ] && set -- "$@" --height "$HEIGHT"
    ;;
esac

# Handle confirm mode separately (no result capture)
if [ "$MODE" = "confirm" ]; then
  if gum "$@"; then
    if [ "$HAS_CMD" = true ] && [ -n "$SAVED_CMD" ]; then
      exec sh -c "$SAVED_CMD"
    fi
    exit 0
  else
    exit 1
  fi
fi

# For choose/filter, pipe in choices
if [ "$MODE" = "choose" ] || [ "$MODE" = "filter" ]; then
  if [ -n "$CHOICES" ]; then
    # Choices provided as positional args
    RESULT=$(printf '%s\n' "$CHOICES" | gum "$@") || exit 130
  elif [ ! -t 0 ]; then
    # Stdin is a pipe, pass it through
    RESULT=$(gum "$@") || exit 130
  else
    echo "Error: No choices provided for $MODE mode" >&2
    echo "Provide choices as arguments or pipe them via stdin" >&2
    exit 1
  fi
else
  # input/write modes
  RESULT=$(gum "$@") || exit 130
fi

# Check for empty result
if [ -z "$RESULT" ] && [ "$ALLOW_EMPTY" != true ]; then
  exit 1
fi

# If no command, just print the result
if [ "$HAS_CMD" = false ] || [ -z "$SAVED_CMD" ]; then
  printf '%s\n' "$RESULT"
  exit 0
fi

# Execute the command with the result
# Check if {} appears in the command
case "$SAVED_CMD" in
  *"{}"*)
    # Replace {} with the result (quote-safe via variable)
    # Use awk to handle the replacement to avoid sed delimiter issues
    EXPANDED_CMD=$(printf '%s' "$SAVED_CMD" | awk -v r="$RESULT" '{gsub(/\{\}/, r)}1')
    exec sh -c "$EXPANDED_CMD"
    ;;
  *)
    # Append result as last argument (skip if empty)
    if [ -n "$RESULT" ]; then
      exec sh -c "$SAVED_CMD \"\$1\"" _ "$RESULT"
    else
      exec sh -c "$SAVED_CMD"
    fi
    ;;
esac
